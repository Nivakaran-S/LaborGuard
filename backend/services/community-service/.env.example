# community-service — copy to .env for local dev / load testing.

# Core
PORT=5002
SERVICE_NAME=community-service
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=laborguard-community

# JWT — must match auth-service.
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-change-me

# Cross-service eventing.
INTERNAL_SERVICE_SECRET=local-dev-internal-service-secret-change-me
NOTIFICATION_SERVICE_URL=http://localhost:5004

# Cloudinary — used for post / story media.
CLOUDINARY_CLOUD_NAME=local-dev-cloud
CLOUDINARY_API_KEY=local-dev-cloud-key
CLOUDINARY_API_SECRET=local-dev-cloud-secret

# Disable NSFW image moderation for local dev / loadtest. The TF.js model is
# ~200 MB and OOMs Render free tier under load. Same flag is set in
# render.yaml for prod free-tier deploys.
DISABLE_NSFW_CHECK=true
NSFW_THRESHOLD=0.85
TOXICITY_THRESHOLD=0.7

# OpenAI — optional, used by content moderation. Dummy is fine.
OPENAI_API_KEY=local-dev-openai-key
