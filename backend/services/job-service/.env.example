# job-service — copy to .env for local dev / load testing.

# Core
PORT=5006
SERVICE_NAME=job-service
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=laborguard-jobs

# JWT — must match auth-service.
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-change-me

# Frontend public URL — used in application status email CTAs.
FRONTEND_URL=http://localhost:5173

# AI contract generation.
GROQ_API_KEY=local-dev-groq-key

# Email (Resend) — used for application status emails.
RESEND_API_KEY=re_local_dev_dummy_key
SYSTEM_DEFAULT_EMAIL=test@example.com
