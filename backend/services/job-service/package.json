{
  "name": "laborguard-job-service",
  "version": "1.0.0",
  "description": "Job Management Service for LaborGuard",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest tests/unit tests/pdfService.test.js --passWithNoTests",
    "test:integration": "jest tests/integration tests/health.test.js --runInBand --passWithNoTests",
    "loadtest": "artillery run tests/performance/load-test.yml"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "pdf-lib": "^1.17.1",
    "resend": "^3.2.0",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "artillery": "^2.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/performance/"
    ]
  }
}
