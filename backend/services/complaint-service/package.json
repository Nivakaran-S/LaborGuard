{
    "name": "complaint-service",
    "version": "1.0.0",
    "description": "Complaint Management Service for LaborGuard",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "nodemon src/index.js",
        "test": "jest --passWithNoTests",
        "test:unit": "jest tests/unit --passWithNoTests",
        "test:integration": "jest tests/integration --runInBand --passWithNoTests",
        "loadtest": "artillery run tests/performance/load-test.yml"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cloudinary": "^2.9.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-validator": "^7.3.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.0.0",
        "multer": "^2.0.2",
        "multer-storage-cloudinary": "^4.0.0",
        "pdfkit": "^0.17.2",
        "resend": "^3.2.0",
        "swagger-ui-express": "^5.0.1",
        "yamljs": "^0.3.0",
        "helmet": "^8.0.0"
    },
    "devDependencies": {
        "artillery": "^2.0.0",
        "jest": "^30.2.0",
        "mongodb-memory-server": "^10.1.4",
        "nodemon": "^3.0.1",
        "supertest": "^7.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testTimeout": 30000,
        "testMatch": ["**/tests/**/*.test.js"],
        "testPathIgnorePatterns": ["/node_modules/", "/tests/performance/"]
    }
}