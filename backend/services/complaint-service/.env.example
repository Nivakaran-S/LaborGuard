# complaint-service — copy to .env for local dev / load testing.

# Core
PORT=5003
SERVICE_NAME=complaint-service
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=laborguard-complaint

# JWT — must match auth-service so tokens verify.
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-change-me

# Cross-service eventing — same value across every backend service.
INTERNAL_SERVICE_SECRET=local-dev-internal-service-secret-change-me

# Sibling service URLs.
NOTIFICATION_SERVICE_URL=http://localhost:5004
COMMUNITY_SERVICE_URL=http://localhost:5002
MESSAGING_SERVICE_URL=http://localhost:5005

# Cloudinary — used for evidence uploads on complaints.
CLOUDINARY_CLOUD_NAME=local-dev-cloud
CLOUDINARY_API_KEY=local-dev-cloud-key
CLOUDINARY_API_SECRET=local-dev-cloud-secret

# Email (Resend) — used for case status / appointment emails.
RESEND_API_KEY=re_local_dev_dummy_key
SYSTEM_DEFAULT_EMAIL=test@example.com
