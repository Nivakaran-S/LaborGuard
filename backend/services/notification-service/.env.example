# notification-service — copy to .env for local dev / load testing.

# Core
PORT=5004
SERVICE_NAME=notification-service
NODE_ENV=development
APP_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=laborguard-notification

# JWT — must match auth-service.
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-change-me

# Cross-service eventing.
INTERNAL_SERVICE_SECRET=local-dev-internal-service-secret-change-me
AUTH_SERVICE_URL=http://localhost:5001

# Email (Resend). Until your domain is verified at resend.com/domains, real
# emails only deliver to the Resend account owner.
RESEND_API_KEY=re_local_dev_dummy_key
SYSTEM_DEFAULT_EMAIL=test@example.com

# Centrifugo — real-time notification push. Empty values gracefully disable
# realtime; the frontend falls back to 30s polling.
CENTRIFUGO_API_KEY=
CENTRIFUGO_API_URL=http://localhost:8000/api
