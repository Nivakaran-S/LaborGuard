{
    "name": "notification-service",
    "version": "1.0.0",
    "description": "Notification Service for LaborGuard",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "nodemon src/index.js",
        "test": "jest --passWithNoTests",
        "test:unit": "jest tests/unit --passWithNoTests",
        "test:integration": "jest tests/integration --runInBand --passWithNoTests",
        "loadtest": "artillery run tests/performance/load-test.yml"
    },
    "dependencies": {
        "@react-email/render": "^2.0.5",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "helmet": "^8.1.0",
        "mongoose": "^8.0.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "resend": "^3.2.0",
        "swagger-ui-express": "^5.0.1",
        "yamljs": "^0.3.0",
        "jsonwebtoken": "^9.0.2"
    },
    "devDependencies": {
        "artillery": "^2.0.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^10.1.4",
        "nodemon": "^3.0.1",
        "supertest": "^7.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testTimeout": 30000,
        "testMatch": ["**/tests/**/*.test.js"],
        "testPathIgnorePatterns": ["/node_modules/", "/tests/performance/"]
    }
}
