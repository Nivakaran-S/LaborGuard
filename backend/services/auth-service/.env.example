# auth-service — copy to .env and fill in for local dev / load testing.
# Render reads its own dashboard env (see render.yaml); this file is only for
# local `npm run dev` and `npm run loadtest`.

# Core
PORT=5001
SERVICE_NAME=auth-service
NODE_ENV=development

# Database — local Mongo or Atlas SRV.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=laborguard-auth

# JWT — must match across services that verify these tokens.
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-change-me
JWT_REFRESH_SECRET=local-dev-jwt-refresh-secret-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_SECRET=local-dev-session-secret-change-me

# Cross-service eventing — same value across every backend service.
INTERNAL_SERVICE_SECRET=local-dev-internal-service-secret-change-me

# Sibling service URLs (auth-service emits user_registered to community,
# moderation events to notification).
COMMUNITY_SERVICE_URL=http://localhost:5002
NOTIFICATION_SERVICE_URL=http://localhost:5004

# Frontend URL — used in OAuth redirects + email CTAs.
FRONTEND_URL=http://localhost:5173

# Google OAuth — passport requires non-empty values to load.
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# Email (Resend). Until your domain is verified at resend.com/domains, real
# emails only deliver to the Resend account owner.
RESEND_API_KEY=re_local_dev_dummy_key
SYSTEM_DEFAULT_EMAIL=test@example.com

# AI document analysis (lawyer/NGO approval).
GROQ_API_KEY=local-dev-groq-key

# Twilio (SMS verification). Leave blank to skip phone OTP.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
