# messaging-service — copy to .env for local dev / load testing.

# Core
PORT=5005
SERVICE_NAME=messaging-service
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=laborguard-messaging

# JWT — must match auth-service.
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-change-me

# Cross-service eventing.
INTERNAL_SERVICE_SECRET=local-dev-internal-service-secret-change-me
NOTIFICATION_SERVICE_URL=http://localhost:5004

# Cloudinary — used for chat attachments (images, video, files).
CLOUDINARY_CLOUD_NAME=local-dev-cloud
CLOUDINARY_API_KEY=local-dev-cloud-key
CLOUDINARY_API_SECRET=local-dev-cloud-secret

# Centrifugo — real-time message push. Empty values gracefully disable
# realtime; the frontend falls back to 8s polling, so loadtest still works.
CENTRIFUGO_API_KEY=
CENTRIFUGO_API_URL=http://localhost:8000/api
