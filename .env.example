# ═══════════════════════════════════════════════════════════════════════════
# LaborGuard — root .env.example
#
# Two unrelated audiences read this file:
#
#   1. Vite (frontend dev) — only the VITE_* prefixed vars at the top.
#      Run from frontend/: `npm run dev` reads root .env automatically.
#
#   2. docker-compose at the project root — reads .env via `env_file: ./.env`
#      and interpolates `${VAR}` references in docker-compose.yml. Backend
#      containers get every variable below.
#
# This file is NOT read by:
#   - Render (uses dashboard env vars — set them in render.yaml sync:false)
#   - Per-service local `npm run dev` (those read backend/services/<name>/.env)
#
# To bootstrap:
#   cp .env.example .env
# Then fill in the real values you have access to. Anything you leave as the
# placeholder will simply make that integration no-op (e.g. blank
# CENTRIFUGO_API_KEY just disables real-time push, doesn't crash).
# ═══════════════════════════════════════════════════════════════════════════


# ── Frontend (Vite) ────────────────────────────────────────────────────────
# The Vite dev server bakes these into the bundle at build time. For local
# dev, point them at localhost ports; for production they come from Vercel
# env vars (set in the Vercel dashboard, not from this file).
VITE_AUTH_SERVICE_URL          = http://localhost:5001/api
VITE_COMMUNITY_SERVICE_URL     = http://localhost:5002/api
VITE_COMPLAINT_SERVICE_URL     = http://localhost:5003/api
VITE_NOTIFICATION_SERVICE_URL  = http://localhost:5004/api
VITE_MESSAGING_SERVICE_URL     = http://localhost:5005/api
VITE_JOB_SERVICE_URL           = http://localhost:5006/api
VITE_CENTRIFUGO_URL            = ws://localhost:8000/connection/websocket
VITE_GOOGLE_CLIENT_ID          = your-google-oauth-client-id
VITE_APP_NAME                  = LaborGuard
VITE_DEFAULT_LANGUAGE          = en


# ── Backend (docker-compose interpolation) ─────────────────────────────────

# MongoDB. For docker-compose use an Atlas SRV string OR a host.docker.internal
# URI for local Mongo. Each service appends its own MONGODB_DB_NAME.
MONGODB_ATLAS_BASE=mongodb://host.docker.internal:27017

# JWT — must be the same across all backend services that verify tokens.
JWT_ACCESS_SECRET=replace-with-32-byte-random-hex-for-local-dev
JWT_REFRESH_SECRET=replace-with-different-32-byte-hex
SESSION_SECRET=replace-with-yet-another-random-string

# Cross-service HTTP eventing — same value across every backend service or
# events get rejected with 403. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_SECRET=replace-with-shared-internal-secret

# Frontend public URL — used by auth-service redirects + email CTAs.
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional for local dev — passport just needs non-empty strings).
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# Google Cloud (only used by auth-service Vertex AI features — leave dummy).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_API_KEY=your-gemini-api-key

# GROQ — optional, used by auth-service for AI document analysis. Dummy is OK.
GROQ_API_KEY=your-groq-api-key

# OpenAI — optional, used by community-service moderation. Dummy is OK.
OPENAI_API_KEY=your-openai-api-key

# Cloudinary — used by community, complaint, messaging for uploads. If left
# as placeholders, uploads will fail at runtime but the service still starts.
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email (Resend) — used by auth, complaint, notification, jobs. Until your
# Resend domain is verified, real emails only deliver to the account owner.
RESEND_API_KEY=re_your_resend_api_key
SYSTEM_DEFAULT_EMAIL=notifications@your-verified-domain.com

# Centrifugo (real-time messaging + notification push). Empty values
# gracefully disable realtime — frontend falls back to 8–15s polling.
CENTRIFUGO_API_KEY=your-centrifugo-api-key

# Twilio (optional — SMS verification). Leave blank to skip phone OTP.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
